# @angular-eslint 18.x pins @typescript-eslint/utils to a range that only
# accepts typescript <6.0, but Angular 22's tooling requires typescript
# ~6.0.3 as a peer. Both are satisfied in practice (eslint and the type
# checker actually work together), but npm's strict resolver rejects the
# graph without this. Remove once @angular-eslint is upgraded past the
# ESLint 9 flat-config migration (see CHANGELOG "Known issues").
legacy-peer-deps=true
